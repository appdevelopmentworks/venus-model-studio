# このファイルをコピーして .env.local を作成する（.env.local はコミットされない）。
# Vercel では Project Settings > Environment Variables に同じキーを登録する。

# 本番の絶対URL。canonical / sitemap / OG画像URL に使われる。
# 例: https://venus-model-studio.com
# 未設定時は Vercel の VERCEL_URL、次に http://localhost:3000 にフォールバックする。
NEXT_PUBLIC_SITE_URL=

# アクセス解析（任意）
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_VERCEL_ANALYTICS=false

# 問い合わせフォームの配信方式
#   mailto: サーバー送信せず、ユーザーのメールソフトを開く（既定）
#   email : Resend でサーバー送信（RESEND_API_KEY と CONTACT_EMAIL が必要）
CONTACT_DELIVERY_MODE=mailto
CONTACT_EMAIL=contact@example.com
RESEND_API_KEY=
